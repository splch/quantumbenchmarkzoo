---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Search · Quantum Benchmark Zoo"
  description="Full-text search across every benchmark entry in the Quantum Benchmark Zoo."
>
  <h1>Search</h1>
  <p class="lede">Full-text search across every benchmark entry.</p>

  <link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
  <script is:inline type="module" src="/pagefind/pagefind-component-ui.js"></script>

  <div class="search-wrap">
    <pagefind-input instance="zoo"></pagefind-input>
    <pagefind-summary instance="zoo"></pagefind-summary>
    <pagefind-filter-dropdown filter="category" label="Category" instance="zoo"></pagefind-filter-dropdown>
    <pagefind-results instance="zoo"></pagefind-results>
  </div>

  <div class="empty-state" id="search-unavailable" hidden>
    <p>
      Search isn't available right now. The search index is generated at build time; if you are
      running the dev server, run <code>pnpm build &amp;&amp; pnpm preview</code> to try it. You can
      also <a href="/">browse and filter all benchmarks</a>.
    </p>
  </div>

  <script is:inline>
    window.addEventListener('load', () => {
      if (!window.customElements || !customElements.get('pagefind-input')) {
        document.getElementById('search-unavailable').hidden = false;
      }
    });
  </script>
</BaseLayout>

<style>
  /* Map Pagefind's --pf-* tokens onto the site palette. Its stylesheet only
     goes dark via a data-pf-theme attribute, never prefers-color-scheme, so
     left alone the results stay light in dark mode. Declared on the wrapper:
     inheritance from the nearest ancestor beats Pagefind's :root defaults
     regardless of stylesheet order. */
  .search-wrap {
    margin-top: 1.5rem;
    display: grid;
    gap: 0.75rem;
    max-width: 44rem;

    --pf-font: var(--font-sans);
    --pf-text: var(--text);
    --pf-text-secondary: var(--muted);
    --pf-text-muted: var(--muted);
    --pf-mark: var(--text);
    --pf-background: var(--bg);
    --pf-border: var(--border);
    --pf-border-focus: var(--border-strong);
    --pf-outline-focus: var(--focus);
    --pf-hover: var(--surface);
    --pf-skeleton: var(--surface);
    --pf-skeleton-shine: var(--border);
    --pf-border-radius: 8px;
    --pf-input-height: 2.625rem;
    --pf-input-font-size: 1rem;
    --pf-summary-font-size: 0.9rem;
    --pf-result-title-font-size: 1.1rem;
    --pf-result-excerpt-font-size: 0.9rem;
    --pf-error-bg: #fef2f2;
    --pf-error-border: #fecaca;
    --pf-error-text: #b91c1c;
    --pf-error-text-secondary: #b91c1c;
  }

  /* The search input is identified by its boundary alone; give it the 3:1
     border, like the filter input on the index page. */
  pagefind-input {
    --pf-border: var(--border-strong);
  }

  @media (prefers-color-scheme: dark) {
    .search-wrap {
      --pf-scroll-shadow: rgba(255, 255, 255, 0.1);
      --pf-error-bg: #2a1a1a;
      --pf-error-border: #5c2828;
      --pf-error-text: #f87171;
      --pf-error-text-secondary: #f87171;
    }
  }
</style>
